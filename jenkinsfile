pipeline {
    agent any
    environment {
        RESOURCE_GROUP = "existing-rg"
        WEB_CODE_PATH = "./web"
        APP_CODE_PATH = "./app"
        DB_SCRIPTS_PATH = "./db-scripts"
    }

    stages {
        stage('Azure Login') {
            steps {
                sh """
                echo "Logging into Azure..."
                az login
                az account set --subscription <your-subscription-id>
                """
            }
        }

        stage('Terraform Init') {
            steps {
                sh "terraform init"
            }
        }

        stage('Terraform Plan') {
            steps {
                sh "terraform plan -var-file=terraform.tfvars"
            }
        }

        stage('Terraform Apply') {
            steps {
                sh "terraform apply -var-file=terraform.tfvars -auto-approve"
            }
        }

        stage('Deploy Web Application') {
            steps {
                sh """
                WEB_APP=$(terraform output -raw web_app_name)
                echo "Deploying Web app to $WEB_APP"
                az webapp deploy --resource-group $RESOURCE_GROUP \
                    --name $WEB_APP \
                    --src-path $WEB_CODE_PATH \
                    --type zip
                """
            }
        }

        stage('Deploy App Application') {
            steps {
                sh """
                APP_SERVICE=$(terraform output -raw app_service_name)
                echo "Deploying App service to $APP_SERVICE"
                az webapp deploy --resource-group $RESOURCE_GROUP \
                    --name $APP_SERVICE \
                    --src-path $APP_CODE_PATH \
                    --type zip
                """
            }
        }

        stage('Run DB Scripts') {
            steps {
                sh """
                SQL_SERVER=$(terraform output -raw sql_server_name)
                SQL_DB=$(terraform output -raw sql_db_name)
                SQL_USER=$(terraform output -raw sql_admin_user)
                SQL_PASS=$(terraform output -raw sql_admin_password)

                echo "Running DB scripts on $SQL_SERVER/$SQL_DB"
                for script in $DB_SCRIPTS_PATH/*.sql; do
                    echo "Running $script..."
                    sqlcmd -S $SQL_SERVER.database.windows.net -d $SQL_DB -U $SQL_USER -P $SQL_PASS -i $script
                done
                """
            }
        }
    }
}